# ============================================================
# Self-UP 后端环境变量示例
# 使用方法：将此文件复制为 .env，填入真实值后启动服务
# ============================================================

# DeepSeek API 密钥（从 https://platform.deepseek.com 获取）
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# JWT 签名密钥（生产环境请替换为随机字符串）
JWT_SECRET_KEY=selfup-dev-secret-change-in-prod

# 数据库路径（可选，默认在 backend/ 目录下生成 selfup.db）
# DATABASE_URL=sqlite:///./selfup.db
